# Theme
theme = TokyoNight Night

# Font — use base font; Ghostty has built-in Nerd Font support
font-family = Ioskeley Mono
font-family-bold = Ioskeley Mono Bold
font-family-italic = Ioskeley Mono Italic
font-family-bold-italic = Ioskeley Mono Bold Italic
font-thicken = true

# Typography
adjust-cell-height = 3

# macOS chrome
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden

# Display
window-colorspace = display-p3
window-padding-balance = true

# Behavior
mouse-hide-while-typing = true
scrollback-limit = 100000

# Keybinds
keybind = shift+enter=text:\n

# Machine-local overrides (fonts, window size, etc.)
config-file = ?~/local/ghostty-overrides
